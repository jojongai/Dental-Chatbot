# --- Frontend (Next.js) ---
# Public base URL for the API (used in browser code).
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend (FastAPI) ---
# Bind address and port for uvicorn when started via apps/api scripts.
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed browser origins for CORS.
CORS_ORIGINS=http://localhost:3000

# SQLAlchemy database URL.
# Local demo (SQLite file under apps/api/data/):
DATABASE_URL=sqlite:///./data/app.db
# Production-like (Supabase Postgres example — use your project connection string):
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres

# --- Gemini LLM ---
GEMINI_API_KEY=your-gemini-api-key-here
# Which model to use (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
# Thinking budget in tokens; 0 = disabled (faster, cheaper for simple turns)
# GEMINI_THINKING_BUDGET=0
#
# Set to false to skip all Gemini calls and use plain-text fallback responses.
# Recommended: keep false during development and in CI to avoid unnecessary API usage.
# Set to true only when you want to demo or test real LLM output.
USE_LLM=false
